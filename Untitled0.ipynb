      "cell_type": "code",
      "source": [
        "nums = list(map(int, input().split()))\n",
        "target = int(input())\n",
        "\n",
        "for i, num1 in enumerate(nums):\n",
        "    for j, num2 in enumerate(nums[i+1:], start=i+1):\n",
        "        if num1 + num2 == target:\n",
        "            print(i, j)"
      ],
